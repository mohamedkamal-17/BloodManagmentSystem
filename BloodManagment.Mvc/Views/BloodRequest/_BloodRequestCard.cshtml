@using BloodManagment.Application.features.BloodRequestfeat.Queries
@model BloodRequestDto

<div class="col-md-4">

    <div class="card p-3 shadow-sm border-0 rounded-4">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h5 class="fw-bold">@Model.PatientName</h5>

                <small class="text-muted">
                    عرض البروفيل
                </small>

            </div>

            <img src="/images/user.png"
                 class="rounded-circle"
                 width="40"
                 height="40" />

        </div>

        <div class="mt-3">

            <p>
                <b>الفصيلة:</b> @Model.BloodGroup
            </p>

            <p>
                <b>الحالة:</b> @Model.Reason
            </p>

            <p>
                <b>الموعد:</b> @Model.RequestDate.ToShortDateString()
            </p>

        </div>

        <div class="d-flex justify-content-between mt-3">
            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-outline-primary"
               data-bs-toggle="modal"
               data-bs-target="#detailsModal">
                عرض
            </a>

            <form asp-action="Accept" method="post">

                <input type="hidden" name="id" value="@Model.Id" />

                <button type="submit" class="btn btn-success">
                    قبول
                </button>

            </form>

            <form asp-action="Delete" method="post">

                <input type="hidden" name="id" value="@Model.Id" />

                <button type="submit" class="btn btn-outline-danger">
                    حذف
                </button>

            </form>

        </div>

    </div>

</div>