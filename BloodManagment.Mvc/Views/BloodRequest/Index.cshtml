
@using BloodManagment.Application.features.BloodRequestfeat.Queries
@model IReadOnlyCollection<BloodRequestDto>

@{
    Layout = "_DashboardLayout";
}

<div class="container-fluid">

    <div class="text-center mb-3">
        <h2 class="fw-bold">الطلبات المستلمة</h2>
        <hr style="width:80%; margin:auto;">
    </div>

    <div class="d-flex justify-content-center gap-3 mb-4">

        <a asp-action="Create" class="btn btn-danger px-4 rounded-pill">
            إضافة طلب
        </a>

        <button class="btn btn-outline-danger px-4 rounded-pill">
            فرز
        </button>

        <input class="form-control w-25" placeholder="ابحث عن أي طلب دم..." />

    </div>

    <!-- Cards -->
    <div class="row g-4">

        @foreach (var item in Model)
        {
            <partial name="_BloodRequestCard" model="item" />
        }

    </div>

</div>

@if (ViewBag.Details != null)
{
    <partial name="_BloodRequestDetails"
             model="ViewBag.Details" />
}


