@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
        body{
            font-family:'Cairo', sans-serif;
            background:#f5f5f5;
        }

        .sidebar{
            width:260px;
            height:100vh;
            position:fixed;
            right:0;
            background:#e8e2d8;
            padding:25px;
        }

        .sidebar a{
            display:block;
            padding:12px;
            margin-bottom:10px;
            border-radius:12px;
            text-decoration:none;
            color:#333;
            background:#dcd6cb;
        }

        .sidebar a.active{
            background:#dc3545;
            color:white;
        }

        .content{
            margin-right:280px;
            padding:30px;
        }
    </style>
</head>
<body>

    <div class="sidebar">

        <h4 class="text-center mb-4">🩸</h4>

        <a asp-controller="Dashboard" asp-action="Index"
           class="@(currentController=="Dashboard" ? "active" : "")">
            الرئيسية
        </a>

        <a asp-controller="BloodRequest" asp-action="Index"
           class="@(currentController=="BloodRequest" ? "active" : "")">
            طلبات الدم
        </a>

        <a asp-controller="User" asp-action="Index"
           class="@(currentController=="User" ? "active" : "")">
            المستخدمين
        </a>

        <a asp-controller="BloodBank" asp-action="Index"
           class="@(currentController=="BloodBank" ? "active" : "")">
            بنك الدم
        </a>

        <hr />

        <a asp-controller="Account" asp-action="Logout">
            تسجيل الخروج
        </a>

    </div>

    <div class="content">
        @RenderBody()
    </div>

</body>
</html>